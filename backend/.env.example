FLASK_APP_SECRET=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=mysql+pymysql://usuario:password@localhost/hardware_ayacucho
FRONTEND_URL=http://localhost:5173
UPLOAD_FOLDER=backend/uploads
BCRYPT_ROUNDS=12
FLASK_ENV=production

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret
CLOUDINARY_FOLDER=hardware-ayacucho/anuncios

# Email delivery modes:
# - testing: solo para tests automatizados
# - log: desarrollo local, registra enlaces en logs
# - smtp: util si tu hosting permite salida SMTP
# - resend_api: recomendado en hosting gratuito si SMTP saliente falla
EMAIL_DELIVERY_MODE=log
EMAIL_PUBLIC_PRODUCTION=false
EMAIL_FROM=no-reply@example.com
EMAIL_SUBJECT_PREFIX=[HardwareAyacucho]
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
RESEND_API_KEY=replace-with-resend-api-key
RESEND_API_BASE_URL=https://api.resend.com/emails
